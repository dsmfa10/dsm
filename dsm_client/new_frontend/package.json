{
  "name": "dsm-wallet",
  "version": "0.1.0-beta.1",
  "private": true,
  "license": "MIT OR Apache-2.0",
  "description": "Production-Ready DSM Wallet React Frontend",
  "main": "src/index.tsx",
  "scripts": {
    "start": "cross-env NODE_ENV=development webpack serve --mode development",
    "build": "npm run build:full-deploy",
    "build:ts": "tsc --project tsconfig.build.json",
    "build:webpack": "cross-env NODE_ENV=production NODE_OPTIONS='--max-old-space-size=2048' webpack --mode production",
    "build:android-webpack": "npm run type-check && npm run lint && cross-env NODE_ENV=production BUILD_TARGET=android NODE_OPTIONS='--max-old-space-size=2048' webpack --mode production",
    "proto:gen": "npx protoc --plugin=protoc-gen-es=./node_modules/.bin/protoc-gen-es --es_out=import_extension=.js:./src/proto --es_opt=target=ts -I ../../proto ../../proto/dsm_app.proto",
    "copy:android": "node scripts/copy-to-android.js",
    "build:android": "cd ../android && ./gradlew assembleDebug",
    "build:full-deploy": "npm run build:android-webpack && npm run copy:android",
    "clean:android": "rimraf ../android/app/src/main/assets/*",
    "test:device": "./test-device.sh",
    "build:nuclear": "node scripts/build-and-deploy-nuclear.js",
    "build:complete": "node scripts/build-complete.js",
    "ensure-bridges": "node scripts/ensure-js-bridges.js",
    "fix-android-assets": "node scripts/fix-missing-assets.js",
    "validate:android-assets": "node scripts/validate-android-assets.js",
    "setup:android-validation": "node scripts/setup-android-validation.js",
    "generate-config": "node ../generate-config.js",
    "gen-bridge-full": "node scripts/generate-bridge-interface.js --rust-path ../deterministic_state_machine/src --output-path ./src/types/generated",
    "cleanup-types": "node scripts/cleanup-types.js",
    "cleanup-types:remove": "node scripts/cleanup-types.js --remove-files",
    "clean": "rimraf dist",
    "type-check": "tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "eslint src -c .eslintrc.production.json --ext .ts,.tsx",
    "lint:fix": "eslint src -c .eslintrc.production.json --ext .ts,.tsx --fix",
    "lint:dev": "eslint 'src/**/*.{ts,tsx}' -c .eslintrc.json",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "test": "cross-env NODE_OPTIONS='--max-old-space-size=4096' jest",
    "test:ci": "cross-env CI=1 NODE_OPTIONS='--max-old-space-size=4096' jest --ci",
    "test:coverage": "cross-env NODE_OPTIONS='--max-old-space-size=4096' jest --coverage",
    "test:ssr": "ts-node -O '{\"module\":\"CommonJS\",\"jsx\":\"react-jsx\"}' scripts/ssr-smoke.ts",
    "analyze": "webpack-bundle-analyzer dist/js/main.*.js",
    "ci": "npm run clean && npm run type-check && npm run lint && npm run test:ci && npm run build:android-webpack && npm run copy:android && npm run validate:android-assets"
  },
  "dependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "buffer": "^6.0.3",
    "html5-qrcode": "^2.3.8",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "7.27.1",
    "@bufbuild/protobuf": "^1.7.2",
    "@bufbuild/protoc-gen-es": "^1.7.0",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.14",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.0",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "cheerio": "^1.1.0",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^13.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-security": "^1.7.1",
    "html-webpack-plugin": "^5.5.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "long": "^5.3.2",
    "mini-css-extract-plugin": "^2.9.4",
    "prettier": "^3.8.1",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "webpack": "^5.105.4",
    "webpack-bundle-analyzer": "^4.9.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.3"
  },
  "overrides": {
    "minimatch": ">=10.0.0",
    "undici": ">=7.10.0",
    "serialize-javascript": ">=7.0.4",
    "lodash": ">=4.17.22",
    "schema-utils": {
      "ajv": ">=8.17.0"
    },
    "qs": ">=6.14.0",
    "@tootallnate/once": ">=2.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
