#!/usr/bin/env bash
# .githooks/pre-push
# Slower checks that run before push (~30–60s).
# Install once with: bash scripts/install-hooks.sh
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

pass() { echo -e "${GREEN}✓${NC} $1"; }
fail() { echo -e "${RED}✗${NC} $1"; exit 1; }
info() { echo -e "${YELLOW}▶${NC} $1"; }

echo ""
echo "┌─────────────────────────────────────────┐"
echo "│           DSM pre-push checks           │"
echo "└─────────────────────────────────────────┘"
echo ""

# ---------------------------------------------------------------------------
# 1. Clippy
# ---------------------------------------------------------------------------
info "Running clippy..."
if ! cargo clippy --all-targets -- -D warnings -A clippy::disallowed_methods 2>&1; then
  fail "cargo clippy failed — fix warnings before pushing"
fi
pass "cargo clippy"

# ---------------------------------------------------------------------------
# 2. Tests
# ---------------------------------------------------------------------------
info "Running test suite..."
if ! cargo test --locked --workspace 2>&1; then
  fail "cargo test failed — fix failing tests before pushing"
fi
pass "cargo test"

# ---------------------------------------------------------------------------
# 3. Codegen enforcement
# ---------------------------------------------------------------------------
info "Checking codegen enforcement..."
bash scripts/codegen_enforce.sh
pass "Codegen enforcement"

info "Checking proto guards..."
bash scripts/guard_protos.sh
pass "Proto guards"

echo ""
echo -e "${GREEN}All pre-push checks passed.${NC}"
echo ""
