{
  "compilerOptions": {
    "target": "ES2021",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": true,
    "exactOptionalPropertyTypes": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.tsbuildinfo",
    "declaration": true,
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@/*": ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/types/*": ["./src/types/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/styles/*": ["./src/styles/*"],
      "@/services/*": ["./src/services/*"],
      "@/bridge/*": ["./src/bridge/*"],
      "@/contexts/*": ["./src/contexts/*"]
    },
    "types": [
      "react",
      "react-dom",
      "node",
      "jest"
    ]
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/proto/dsm_app.ts",
    "src/proto/google/protobuf/**",
    "scripts/**",
    "src/**/*.old.tsx",
    "src/**/*.legacy.ts",
    "src/**/*.legacy.tsx",
    // Temporarily exclude unmigrated bufbuild-style modules until ts-proto migration completes
    "src/dsm/index.ts",
    "src/contexts/BleContext.tsx",
    "src/services/bleBridge.ts",
    "src/services/dsmClientNew.ts",
    "src/services/headerService.ts",
    "**/__mocks__/**"
  ]
}